# Dependencies
node_modules/

# SQLite database file (auto-generated, contains user data)
# Prisma resolves file:./crm.db relative to backend/prisma/ → backend/prisma/crm.db
backend/prisma/*.db
backend/prisma/*.db-shm
backend/prisma/*.db-wal
backend/prisma/*.db-journal
# Catch nested db paths created by alternate DATABASE_URL configurations
backend/prisma/**/*.db
backend/prisma/**/*.db-shm
backend/prisma/**/*.db-wal
backend/prisma/**/*.db-journal

# Build artifacts
frontend/dist/

# Environment files (contain secrets – copy from .env.example)
backend/.env
frontend/.env

# Logs
*.log
npm-debug.log*

# OS files
.DS_Store
Thumbs.db
.vs