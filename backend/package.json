{
  "name": "crm-backend",
  "version": "1.0.0",
  "description": "CRM Backend for Oracle Cloud Inventory & Misc Receipt Management",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "node prisma/seed.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:wsdl": "node scripts/test-wsdl.js",
    "test:receipt": "node scripts/test-single-receipt.js",
    "discover:methods": "node scripts/discover-methods.js",
    "discover:methods:verbose": "node scripts/discover-methods.js --verbose"
  },
  "dependencies": {
    "@prisma/client": "^5.7.0",
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "csv-parse": "^5.5.3",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "fast-xml-parser": "^5.7.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "p-limit": "^3.1.0",
    "p-retry": "^4.6.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "nodemon": "^3.0.2",
    "prisma": "^5.7.0",
    "supertest": "^7.2.2"
  }
}
