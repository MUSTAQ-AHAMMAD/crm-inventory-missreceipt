# Backend environment variables – copy this file to .env

# SQLite database file path (relative to backend/prisma/schema.prisma location)
# Prisma resolves this to:  backend/prisma/crm.db  (created automatically)
DATABASE_URL=file:./crm.db

# JWT secret key (use a long random string in production)
JWT_SECRET=your-super-secret-jwt-key
JWT_EXPIRES_IN=24h

# Oracle Cloud credentials (used for both REST & SOAP APIs)
ORACLE_USERNAME=Ramana@ibrahimalqurashi.com
ORACLE_PASSWORD=159159159

# Oracle REST API endpoint for inventory staged transactions
ORACLE_INVENTORY_API_URL=https://ehxk-test.fa.em2.oraclecloud.com/fscmRestApi/resources/11.13.18.05/inventoryStagedTransactions

# Oracle REST API endpoint for standard receipts
ORACLE_STANDARD_RECEIPT_API_URL=https://ehxk.fa.em2.oraclecloud.com/fscmRestApi/resources/11.13.18.05/standardReceipts

# Oracle SOAP endpoint for miscellaneous receipts
ORACLE_SOAP_URL=https://ehxk-test.fa.em2.oraclecloud.com/fscmService/MiscellaneousReceiptService

# Oracle REST API endpoint for receivables invoices lookup (Apply Receipt)
ORACLE_RECEIVABLES_INVOICES_API_URL=https://ehxk-test.fa.em2.oraclecloud.com/fscmRestApi/resources/11.13.18.05/receivablesInvoices

# Oracle REST API endpoint for standard receipts lookup (Apply Receipt)
ORACLE_STANDARD_RECEIPTS_LOOKUP_API_URL=https://ehxk-test.fa.em2.oraclecloud.com/fscmRestApi/resources/11.13.18.05/standardReceipts

# Oracle SOAP endpoint for apply receipt
ORACLE_APPLY_RECEIPT_SOAP_URL=https://ehxk.fa.em2.oraclecloud.com/fscmService/StandardReceiptService

# Server port
PORT=4000

# Frontend origin (used for CORS)
FRONTEND_URL=http://localhost:3000

# Bulk upload performance settings
# Number of concurrent API requests (default: 5)
# Higher values = faster processing but more load on Oracle
# Lower values = slower but safer for Oracle API rate limits
CONCURRENT_REQUESTS=5

# Maximum retry attempts for failed API calls (default: 3)
# Failed requests will be retried with exponential backoff
MAX_RETRIES=3
