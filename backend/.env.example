# Backend environment variables – copy to .env and fill in your values

# PostgreSQL connection string
DATABASE_URL=postgresql://crm_user:crm_password@localhost:5432/crm_db

# JWT secret key (use a long random string in production)
JWT_SECRET=your-super-secret-jwt-key
JWT_EXPIRES_IN=24h

# Oracle Cloud credentials (used for both REST & SOAP APIs)
ORACLE_USERNAME=Ramana@ibrahimalqurashi.com
ORACLE_PASSWORD=159159159

# Oracle REST API endpoint for inventory staged transactions
ORACLE_INVENTORY_API_URL=https://ehxk-test.fa.em2.oraclecloud.com/fscmRestApi/resources/11.13.18.05/inventoryStagedTransactions

# Oracle SOAP endpoint for miscellaneous receipts
ORACLE_SOAP_URL=https://ehxk-test.fa.em2.oraclecloud.com/fscmService/MiscellaneousReceiptService

# Server port
PORT=4000

# Frontend origin (used for CORS)
FRONTEND_URL=http://localhost:3000
