// Prisma schema for CRM Inventory & Misc Receipt application
// Uses SQLite for zero-install local deployment on Windows / macOS / Linux

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // SQLite – a single file database, no server required
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// NOTE: SQLite does not support native enums.
// The `role` field is stored as a plain String.
// Valid values: "ADMIN", "MANAGER", "USER"

// User model – stores authentication credentials and role information
model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  role         String   @default("USER")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  inventoryUploads   InventoryUpload[]
  miscReceiptUploads MiscReceiptUpload[]
  standardReceiptUploads StandardReceiptUpload[]
  activityLogs       ActivityLog[]
}

// Tracks each bulk inventory CSV upload and its processing results
model InventoryUpload {
  id               Int      @id @default(autoincrement())
  userId           Int
  user             User     @relation(fields: [userId], references: [id])
  filename         String
  organizationName String   @default("")
  totalRecords     Int      @default(0)
  successCount     Int      @default(0)
  failureCount     Int      @default(0)
  status           String   @default("PENDING")
  createdAt        DateTime @default(now())

  failures  InventoryFailureRecord[]
  successes InventorySuccessRecord[]
}

// Stores individual rows that succeeded during an inventory upload
// NOTE: rawData is stored as a JSON string (SQLite has no native JSON type)
model InventorySuccessRecord {
  id        Int             @id @default(autoincrement())
  uploadId  Int
  upload    InventoryUpload @relation(fields: [uploadId], references: [id])
  rowNumber Int
  rawData   String
  createdAt DateTime        @default(now())
}

// Stores individual rows that failed during an inventory upload
// NOTE: rawData is stored as a JSON string (SQLite has no native JSON type)
model InventoryFailureRecord {
  id           Int             @id @default(autoincrement())
  uploadId     Int
  upload       InventoryUpload @relation(fields: [uploadId], references: [id])
  rowNumber    Int
  rawData      String
  errorMessage String
  createdAt    DateTime        @default(now())
}

// Tracks each miscellaneous receipt CSV upload and its SOAP response
model MiscReceiptUpload {
  id              Int      @id @default(autoincrement())
  userId          Int
  user            User     @relation(fields: [userId], references: [id])
  filename        String
  xmlPayload      String
  responseStatus  String?
  responseMessage String?
  responseLog     String?
  createdAt       DateTime @default(now())

  failures MiscReceiptFailure[]
}

// Stores rows that failed during a misc receipt upload
// NOTE: rawData is stored as a JSON string (SQLite has no native JSON type)
model MiscReceiptFailure {
  id           Int               @id @default(autoincrement())
  uploadId     Int
  upload       MiscReceiptUpload @relation(fields: [uploadId], references: [id])
  rowNumber    Int
  rawData      String
  errorMessage String
  createdAt    DateTime          @default(now())
}

// Tracks each standard receipt CSV upload and its REST responses
model StandardReceiptUpload {
  id              Int      @id @default(autoincrement())
  userId          Int
  user            User     @relation(fields: [userId], references: [id])
  filename        String
  payloadJson     String
  totalRecords    Int      @default(0)
  successCount    Int      @default(0)
  failureCount    Int      @default(0)
  status          String   @default("PROCESSING")
  responseMessage String?
  responseLog     String?
  createdAt       DateTime @default(now())

  failures StandardReceiptFailure[]
}

// Stores rows that failed during a standard receipt upload
// NOTE: rawData is stored as a JSON string (SQLite has no native JSON type)
model StandardReceiptFailure {
  id           Int                   @id @default(autoincrement())
  uploadId     Int
  upload       StandardReceiptUpload @relation(fields: [uploadId], references: [id])
  rowNumber    Int
  rawData      String
  errorMessage String
  createdAt    DateTime              @default(now())
}

// Audit log for all user actions within the system
model ActivityLog {
  id            Int      @id @default(autoincrement())
  userId        Int
  user          User     @relation(fields: [userId], references: [id])
  actionType    String
  actionDetails String
  ipAddress     String?
  createdAt     DateTime @default(now())
}
