// Prisma schema for CRM Inventory & Misc Receipt application
// Uses SQLite for zero-install local deployment on Windows / macOS / Linux

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // SQLite – a single file database, no server required
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// NOTE: SQLite does not support native enums.
// The `role` field is stored as a plain String.
// Valid values: "ADMIN", "MANAGER", "USER"

// User model – stores authentication credentials and role information
model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  role         String   @default("USER")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  inventoryUploads   InventoryUpload[]
  miscReceiptUploads MiscReceiptUpload[]
  standardReceiptUploads StandardReceiptUpload[]
  applyReceiptUploads ApplyReceiptUpload[]
  arInvoiceUploads   ArInvoiceUpload[]
  arInvoiceData      ArInvoiceData[]
  activityLogs       ActivityLog[]
}

// Tracks each bulk inventory CSV upload and its processing results
model InventoryUpload {
  id               Int      @id @default(autoincrement())
  userId           Int
  user             User     @relation(fields: [userId], references: [id])
  filename         String
  organizationName String   @default("")
  totalRecords     Int      @default(0)
  successCount     Int      @default(0)
  failureCount     Int      @default(0)
  status           String   @default("PENDING")
  createdAt        DateTime @default(now())

  failures  InventoryFailureRecord[]
  successes InventorySuccessRecord[]
}

// Stores individual rows that succeeded during an inventory upload
// NOTE: rawData is stored as a JSON string (SQLite has no native JSON type)
model InventorySuccessRecord {
  id        Int             @id @default(autoincrement())
  uploadId  Int
  upload    InventoryUpload @relation(fields: [uploadId], references: [id])
  rowNumber Int
  rawData   String
  responseBody String?
  responseStatus Int?
  createdAt DateTime        @default(now())
}

// Stores individual rows that failed during an inventory upload
// NOTE: rawData is stored as a JSON string (SQLite has no native JSON type)
model InventoryFailureRecord {
  id                  Int             @id @default(autoincrement())
  uploadId            Int
  upload              InventoryUpload @relation(fields: [uploadId], references: [id])
  rowNumber           Int
  rawData             String
  errorMessage        String
  responseBody        String?
  responseStatus      Int?
  oracleErrorCode     String?   // e.g. "INV_INVALID_ITEM" — Oracle ErrorCode field
  oracleProcessStatus String?   // e.g. "3" — Oracle ProcessStatus: 1=success, 3=error
  createdAt           DateTime        @default(now())
}

// Tracks each miscellaneous receipt CSV upload and its SOAP response
model MiscReceiptUpload {
  id              Int      @id @default(autoincrement())
  userId          Int
  user            User     @relation(fields: [userId], references: [id])
  filename        String
  xmlPayload      String
  responseStatus  String?
  responseMessage String?
  responseLog     String?
  createdAt       DateTime @default(now())

  failures MiscReceiptFailure[]
}

// Stores rows that failed during a misc receipt upload
// NOTE: rawData is stored as a JSON string (SQLite has no native JSON type)
model MiscReceiptFailure {
  id              Int               @id @default(autoincrement())
  uploadId        Int
  upload          MiscReceiptUpload @relation(fields: [uploadId], references: [id])
  rowNumber       Int
  rawData         String
  errorMessage    String
  requestPayload  String?           // Full SOAP XML request sent to Oracle
  responseBody    String?           // Full response body from Oracle
  responseStatus  Int?              // HTTP status code from Oracle
  createdAt       DateTime          @default(now())
}

// Tracks each standard receipt CSV upload and its REST responses
model StandardReceiptUpload {
  id              Int      @id @default(autoincrement())
  userId          Int
  user            User     @relation(fields: [userId], references: [id])
  filename        String
  payloadJson     String
  totalRecords    Int      @default(0)
  successCount    Int      @default(0)
  failureCount    Int      @default(0)
  status          String   @default("PROCESSING")
  responseMessage String?
  responseLog     String?
  createdAt       DateTime @default(now())

  failures StandardReceiptFailure[]
}

// Stores rows that failed during a standard receipt upload
// NOTE: rawData is stored as a JSON string (SQLite has no native JSON type)
model StandardReceiptFailure {
  id              Int                   @id @default(autoincrement())
  uploadId        Int
  upload          StandardReceiptUpload @relation(fields: [uploadId], references: [id])
  rowNumber       Int
  rawData         String
  errorMessage    String
  requestPayload  String?               // Full JSON payload sent to Oracle
  responseBody    String?               // Full response body from Oracle
  responseStatus  Int?                  // HTTP status code from Oracle
  createdAt       DateTime              @default(now())
}

// Tracks each apply receipt CSV upload and its processing results
model ApplyReceiptUpload {
  id              Int      @id @default(autoincrement())
  userId          Int
  user            User     @relation(fields: [userId], references: [id])
  filename        String
  totalRecords    Int      @default(0)
  totalReceipts   Int      @default(0)
  successCount    Int      @default(0)
  failureCount    Int      @default(0)
  status          String   @default("PROCESSING")
  responseMessage String?
  responseLog     String?
  createdAt       DateTime @default(now())

  failures ApplyReceiptFailure[]
}

// Stores rows that failed during an apply receipt upload
// NOTE: rawData is stored as a JSON string (SQLite has no native JSON type)
model ApplyReceiptFailure {
  id                 Int                @id @default(autoincrement())
  uploadId           Int
  upload             ApplyReceiptUpload @relation(fields: [uploadId], references: [id])
  rowNumber          Int
  invoiceNumber      String
  receiptNumber      String
  errorMessage       String
  errorStep          String             // "INVOICE_LOOKUP", "RECEIPT_LOOKUP", "APPLY_RECEIPT"
  requestPayload     String?            // REST query or SOAP XML
  responseBody       String?
  responseStatus     Int?
  customerTrxId      String?            // Captured even if apply fails
  receiptId          String?            // Captured even if apply fails
  createdAt          DateTime           @default(now())
}

// Tracks each AR Invoice creation and its Oracle REST API response
model ArInvoiceUpload {
  id              Int      @id @default(autoincrement())
  userId          Int
  user            User     @relation(fields: [userId], references: [id])
  payloadJson     String   // The full JSON payload sent to Oracle
  responseStatus  String?  // SUCCESS, FAILED, PROCESSING
  responseMessage String?  // Summary message
  responseBody    String?  // Full Oracle API response
  httpStatus      Int?     // HTTP status code from Oracle
  createdAt       DateTime @default(now())
}

// Audit log for all user actions within the system
model ActivityLog {
  id            Int      @id @default(autoincrement())
  userId        Int
  user          User     @relation(fields: [userId], references: [id])
  actionType    String
  actionDetails String
  ipAddress     String?
  createdAt     DateTime @default(now())
}

// Fusion Sales Metadata - lookup table for mapping sales data to AR invoices
// Contains customer, business unit, and transaction source information
model FusionSalesMetadata {
  id                   Int     @id @default(autoincrement())
  rowId                Int     @unique
  billToName           String
  billToAccount        Int
  siteNumber           String
  businessUnit         String
  txnSource            String
  txnType              String
  rateIsCorporate      String
  recActivityNameBank  String
  subinventory         String
  integrationSource    String
  distributionAccId    String?
  recActivityNameCash  String
  region               String
  customerType         String
  costCenterCode       String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

// AR Invoice Data - stores individual AR invoice line items for bulk operations
// Can be populated via CSV upload or manual entry, then used to generate Oracle payloads
model ArInvoiceData {
  id                      Int      @id @default(autoincrement())

  // Header information
  customerName            String
  customerNumber          String
  siteNumber              String
  subinventory            String?
  businessUnit            String
  transactionSource       String
  transactionType         String
  transactionDate         String   // YYYY-MM-DD format
  accountingDate          String   // YYYY-MM-DD format
  paymentTerms            String
  invoiceCurrencyCode     String
  crossReference          String?
  comments                String?

  // Line item information
  lineNumber              Int
  itemNumber              String
  description             String
  quantity                Float
  unitSellingPrice        Float
  taxClassificationCode   String
  salesOrder              String?
  memoLine                String?

  // Metadata
  userId                  Int
  user                    User     @relation(fields: [userId], references: [id])
  uploadBatchId           String?  // Group multiple lines from same CSV upload
  status                  String   @default("PENDING") // PENDING, PROCESSED, FAILED
  processedAt             DateTime?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([customerName, subinventory])
  @@index([uploadBatchId])
  @@index([status])
}
